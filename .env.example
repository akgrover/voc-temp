# VoC Pipeline Configuration
# Copy this file to .env and fill in your actual values

# =====================================================================
# Anthropic API Configuration
# =====================================================================
ANTHROPIC_API_KEY=your-api-key-here

# =====================================================================
# Database Configuration (PostgreSQL)
# Optional — leave empty to run without persistence
# =====================================================================
DATABASE_URL=postgresql://username:password@localhost:5432/voc

# =====================================================================
# Kafka Configuration (Optional)
# Only needed if running the Kafka consumer (pipeline.py)
# =====================================================================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_INPUT_TOPIC=raw-feedback
KAFKA_GROUP_ID=voc-pipeline
KAFKA_OUTPUT_TOPIC=

# =====================================================================
# Pipeline Configuration
# =====================================================================
# Batch size for Kafka consumer
BATCH_SIZE=50

# Batch timeout in milliseconds
BATCH_TIMEOUT_MS=5000

# Number of worker threads for parallel stages
MAX_WORKERS=8

# LLM Model for complex tasks (unitization, topic extraction)
LLM_MODEL_COMPLEX=claude-sonnet-4-6

# LLM Model for simple tasks (sentiment, intent)
LLM_MODEL_SIMPLE=claude-haiku-4-5-20251001

# Sentence transformer model for embeddings
ENCODER_MODEL=all-MiniLM-L6-v2

# =====================================================================
# API Configuration
# =====================================================================
API_PORT=8000
API_RELOAD=true
